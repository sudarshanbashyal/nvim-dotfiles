{
	"coc.preferences.formatOnSaveFiletypes": [
		"javascript",
		"typescript",
		"typescriptreact",
		"json",
		"javascriptreact",
		"xml",
		"prisma"
	],
	"snippets.ultisnips.directories": [
		"UltiSnips",
		"~/.config/nvim/utils/snips"
	],
	"prettier.tabWidth": 4,
	"prettier.useTabs": true,
	"prettier.arrowParens": "always",
	"prettier.proseWrap": "always"
}
